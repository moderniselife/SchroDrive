{
  "name": "schrodrive",
  "version": "0.5.3",
  "private": true,
  "description": "Unified cloud debrid mount manager — integrates Overseerr, Prowlarr/Jackett, RealDebrid, TorBox, Plex, Jellyfin, and Emby",
  "main": "dist/index.js",
  "bin": {
    "schrodrive": "dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/index.js serve",
    "serve": "bun dist/index.js serve",
    "dev": "bun --watch src/index.ts serve",
    "typecheck": "tsc --noEmit",
    "test:integration": "bun tests/integration.test.ts"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-torbox-api": "^0.1.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  }
}
